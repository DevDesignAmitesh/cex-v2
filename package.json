{
  "name": "cex-v2",
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "db:migrate": "cd packages/db && bunx prisma migrate dev",
    "db:studio": "cd packages/db && bunx prisma studio",
    "db:reset": "cd packages/db && bunx prisma migrate reset",
    "db:generate": "cd packages/db && bunx prisma generate"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
