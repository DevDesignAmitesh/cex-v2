generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id       @default(uuid())
  email         String    @unique
  username      String
  password      String

  orders        Order[]

  makerFills    Fill[]    @relation("maker")
  takerFills    Fill[]    @relation("taker")
}

model Order {
  id        String        @id       @default(uuid())
  userId    String
  user      User          @relation(references: [id], fields: [userId], onDelete: Cascade)
  market    orderMarket
  price     Int
  qty       Int
  filledQty Int
  side      orderSide
  type      orderType
  status    orderStatus

  makerFills Fill[]       @relation("maker_order")
  takerFills Fill[]       @relation("taker_order")
}

model Fill {
  id            String         @id       @default(uuid())

  askedQty      Int
  filledQty     Int
  side          orderSide
  type          fillType
  price         Int
  asset         orderMarket

  makerId       String
  maker         User          @relation("maker", references: [id], fields: [makerId])

  takerId       String
  taker         User          @relation("taker", references: [id], fields: [takerId])

  makerOrderId  String
  makerOrder    Order         @relation("maker_order", references: [id], fields: [makerOrderId], onDelete: Cascade)

  takerOrderId  String
  takerOrder    Order         @relation("taker_order", references: [id], fields: [takerOrderId], onDelete: Cascade)
}

enum fillType {
  MAKER
  TAKER
}

enum orderStatus {
  OPEN
  FILLED
  CANCELLED
  PARTIAL_FILLED
}

enum orderType {
  LIMIT
  MARKET
}

enum orderMarket {
  AXIS
  TATA
}

enum orderSide {
  SELL
  BUY
}
